<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>de.mpsc</groupId>
  <artifactId>lod2-zu-lod3</artifactId>
  <name>lod2-zu-lod3</name>
  <version>0.1.0-SNAPSHOT</version>
  <description>LoD2 CityGML zu LoD3 Konvertierung mit Keller, Fenstern, Türen und Balkonen</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>21</release>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>de.mpsc.lod2tolod3.Lod2ToLod3Basement</mainClass>
            </manifest>
          </archive>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <id>pipeline</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>de.mpsc.lod2tolod3.Lod2ToLod3Pipeline</mainClass>
                </transformer>
                <transformer />
              </transformers>
              <finalName>lod2-zu-lod3-pipeline</finalName>
            </configuration>
          </execution>
          <execution>
            <id>converter</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>de.mpsc.lod2tolod3.Lod2ToLod3Promoter</mainClass>
                </transformer>
                <transformer />
              </transformers>
              <finalName>lod2-to-lod3-promoter</finalName>
            </configuration>
          </execution>
          <execution>
            <id>basement</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>de.mpsc.lod2tolod3.BasementGenerator</mainClass>
                </transformer>
                <transformer />
              </transformers>
              <finalName>lod3-basement-generator</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.release>21</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <citygml4j.version>3.2.7</citygml4j.version>
  </properties>
</project>
